def setup_directories(hps):
    """创建并验证所有必要的目录结构"""
    # 确保基础目录存在
    os.makedirs(hps.model_dir, exist_ok=True)
    os.makedirs("logs", exist_ok=True)
    
    # 创建版本化目录
    version_dir = hps.train.tensorboard_log_dir
    os.makedirs(version_dir, exist_ok=True)
    
    # 创建检查点目录
    checkpoint_dir = hps.train.checkpoint_dir
    os.makedirs(checkpoint_dir, exist_ok=True)
    
    # 创建模型保存目录
    save_dir = hps.train.save_dir
    os.makedirs(save_dir, exist_ok=True)
    
    # 移动错误位置的事件文件
    moved_files = []
    for event_file in glob.glob("events.out.tfevents.*"):
        dest = os.path.join(version_dir, event_file)
        try:
            if os.path.exists(event_file):
                shutil.move(event_file, dest)
                moved_files.append(dest)
        except Exception as e:
            print(f"⚠️ 移动文件失败: {e}")
    
    # 记录目录状态
    setup_log_path = os.path.join(version_dir, "setup.log")
    with open(setup_log_path, "w") as f:
        f.write(f"Directory setup at {datetime.now()}\n")
        f.write(f"TensorBoard log dir: {version_dir}\n")
        f.write(f"Checkpoint dir: {checkpoint_dir}\n")
        f.write(f"Model save dir: {save_dir}\n")
        if moved_files:
            f.write(f"Moved {len(moved_files)} event files to correct location\n")
    
    print(f"✅ 目录设置完成:")
    print(f"  - TensorBoard: {version_dir}")
    print(f"  - Checkpoints: {checkpoint_dir}")
    print(f"  - Models: {save_dir}")
    
    # 验证目录是否可写
    test_file_path = os.path.join(version_dir, "write_test.txt")
    try:
        with open(test_file_path, "w") as f:
            f.write("Directory write test - success\n")
        os.remove(test_file_path)
        print("✅ 目录写入权限验证通过")
    except Exception as e:
        print(f"❌ 目录写入权限验证失败: {e}")
        raise
    
    return {
        "version_dir": version_dir,
        "checkpoint_dir": checkpoint_dir,
        "save_dir": save_dir
    }

def validate_and_fix_dataset(hps):
    """验证数据集完整性并自动修复"""
    print("\n" + "="*80)
    print("🔍 验证数据集完整性...")
    
    # 获取所有文件列表
    def read_file_list(file_path):
        with open(file_path, 'r', encoding='utf-8') as f:
            return [line.split('|')[0].strip() for line in f]
    
    train_files = read_file_list(hps.data.training_files)
    val_files = read_file_list(hps.data.validation_files)
    all_files = set(train_files + val_files)
    
    # 检查特征文件是否存在
    missing_files = []
    for wav_path in all_files:
        feature_path = wav_path + '.soft.pt'
        if not os.path.exists(feature_path):
            missing_files.append(feature_path)
            print(f"⚠️ 缺失特征文件: {feature_path}")
    
    if not missing_files:
        print("✅ 所有特征文件完整")
        return
    
    print(f"\n🔧 发现 {len(missing_files)} 个缺失特征文件, 尝试修复...")
    
    # 尝试重新生成特征文件
    def run_preprocess_scripts():
        print("\n🔄 运行预处理脚本...")
        scripts = [
            "preprocess_flist_config.py",
            "preprocess_hubert_f0.py"
        ]
        
        for script in scripts:
            if os.path.exists(script):
                cmd = f"python {script} --speech_encoder vec768l12"
                print(f"执行: {cmd}")
                result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
                if result.returncode == 0:
                    print(f"✅ {script} 执行成功")
                else:
                    print(f"❌ {script} 执行失败: {result.stderr}")
            else:
                print(f"⚠️ 预处理脚本 {script} 不存在")
    
    run_preprocess_scripts()
    
    # 再次检查是否修复成功
    still_missing = []
    for feature_path in missing_files:
        if not os.path.exists(feature_path):
            still_missing.append(feature_path)
    
    if not still_missing:
        print("✅ 所有缺失文件已成功修复")
        return
    
    print(f"\n⚠️ 仍有 {len(still_missing)} 个文件无法修复, 从文件列表中移除...")
    
    # 从文件列表中移除问题文件
    def clean_file_list(file_path, files_to_remove):
        base_names = [os.path.basename(path).replace('.soft.pt', '') for path in files_to_remove]
        new_lines = []
        removed_count = 0
        
        with open(file_path, 'r', encoding='utf-8') as f:
            for line in f:
                if not any(name in line for name in base_names):
                    new_lines.append(line)
                else:
                    removed_count += 1
        
        # 备份原文件
        backup_path = f"{file_path}.bak"
        shutil.copy(file_path, backup_path)
        print(f"  - 创建备份: {backup_path}")
        
        # 写入新文件
        with open(file_path, 'w', encoding='utf-8') as f:
            f.writelines(new_lines)
        
        return removed_count
    
    # 清理训练和验证文件列表
    print("\n🧹 清理文件列表:")
    train_removed = clean_file_list(hps.data.training_files, still_missing)
    val_removed = clean_file_list(hps.data.validation_files, still_missing)
    
    print(f"  - 从训练集中移除 {train_removed} 个文件")
    print(f"  - 从验证集中移除 {val_removed} 个文件")
    print("✅ 文件列表清理完成")
    print("="*80 + "\n")

def main():
    """主训练函数 - 单节点多GPU训练"""
    assert torch.cuda.is_available(), "CPU训练不被支持"
    hps = utils.get_hparams()
    
    # ====== 数据集完整性检查 ======
    validate_and_fix_dataset(hps)
    
    # ====== 目录设置 ======
    print("🛠️ 正在设置目录结构...")
    dirs = setup_directories(hps)
    # =====================
    
    n_gpus = torch.cuda.device_count()
    os.environ['MASTER_ADDR'] = 'localhost'
    os.environ['MASTER_PORT'] = hps.train.port

    try:
        # 启动多进程训练
        mp.spawn(run, nprocs=n_gpus, args=(n_gpus, hps, dirs))
    except KeyboardInterrupt:
        print("\n🛑 训练被用户中断 - 程序退出")
    except Exception as e:
        print(f"❌ 训练遇到错误: {e}")
        raise
    finally:
        print("🧹 清理资源...")

def run(rank, n_gpus, hps, dirs):
    """每个GPU上运行的训练进程"""
    global global_step
    writer = None
    writer_eval = None
    
    try:
        if rank == 0:
            print(f"🚀 在GPU {rank}上启动主训练进程")
            logger = utils.get_logger(hps.model_dir)
            logger.info(hps)
            utils.check_git_hash(hps.model_dir)
            
            # TensorBoard初始化
            writer = SummaryWriter(log_dir=dirs["version_dir"])
            eval_log_dir = os.path.join(dirs["version_dir"], "eval")
            os.makedirs(eval_log_dir, exist_ok=True)
            writer_eval = SummaryWriter(log_dir=eval_log_dir)
            print(f"📊 TensorBoard日志路径: {dirs['version_dir']}")
        
        # 初始化分布式训练
        dist.init_process_group(
            backend='gloo' if os.name == 'nt' else 'nccl',
            init_method='env://',
            world_size=n_gpus,
            rank=rank
        )
        
        torch.manual_seed(hps.train.seed)
        torch.cuda.set_device(rank)
        
        # 数据加载器
        collate_fn = TextAudioCollate()
        all_in_mem = hps.train.all_in_mem
        train_dataset = TextAudioSpeakerLoader(hps.data.training_files, hps, all_in_mem=all_in_mem)
        
        num_workers = min(4, multiprocessing.cpu_count())  # 限制worker数量
        if all_in_mem:
            num_workers = 0
            
        train_loader = DataLoader(
            train_dataset,
            num_workers=num_workers,
            shuffle=False,
            pin_memory=True,
            batch_size=hps.train.batch_size,
            collate_fn=collate_fn
        )
        
        if rank == 0:
            eval_dataset = TextAudioSpeakerLoader(hps.data.validation_files, hps, all_in_mem=all_in_mem, vol_aug=False)
            eval_loader = DataLoader(
                eval_dataset,
                num_workers=1,
                shuffle=False,
                batch_size=1,
                pin_memory=False,
                drop_last=False,
                collate_fn=collate_fn
            )

        # 初始化模型
        net_g = SynthesizerTrn(
            hps.data.filter_length // 2 + 1,
            hps.train.segment_size // hps.data.hop_length,
            **hps.model
        ).cuda(rank)
        
        net_d = MultiPeriodDiscriminator(hps.model.use_spectral_norm).cuda(rank)
        
        # 优化器
        optim_g = torch.optim.AdamW(
            net_g.parameters(),
            hps.train.learning_rate,
            betas=hps.train.betas,
            eps=hps.train.eps
        )
        
        optim_d = torch.optim.AdamW(
            net_d.parameters(),
            hps.train.learning_rate,
            betas=hps.train.betas,
            eps=hps.train.eps
        )
        
        # 分布式数据并行
        net_g = DDP(net_g, device_ids=[rank])
        net_d = DDP(net_d, device_ids=[rank])

        # ====== 自动恢复训练 ======
        epoch_str = 1
        global_step = 0
        skip_optimizer = False
        
        try:
            # 安全地获取检查点路径
            def safe_get_checkpoint(pattern):
                try:
                    return utils.latest_checkpoint_path(hps.model_dir, pattern)
                except IndexError:
                    return None
                    
            g_checkpoint = safe_get_checkpoint("G_*.pth")
            d_checkpoint = safe_get_checkpoint("D_*.pth")
            
            if rank == 0:
                print(f"🔍 G检查点: {g_checkpoint or '未找到'}")
                print(f"🔍 D检查点: {d_checkpoint or '未找到'}")
            
            # 只有当两个检查点都存在时才加载
            if g_checkpoint and d_checkpoint:
                # 尝试加载生成器检查点
                _, _, _, epoch_str = utils.load_checkpoint(
                    g_checkpoint,
                    net_g, optim_g, skip_optimizer
                )
                
                # 尝试加载判别器检查点
                _, _, _, epoch_str = utils.load_checkpoint(
                    d_checkpoint,
                    net_d, optim_d, skip_optimizer
                )
                
                # 从文件名提取全局步数
                try:
                    global_step = int(os.path.basename(g_checkpoint).split('_')[1].split('.')[0]) + 1
                except:
                    global_step = 0
                    
                if rank == 0:
                    print(f"🔁 从检查点恢复: epoch={epoch_str}, step={global_step}")
            else:
                if rank == 0:
                    print("⚠️ 检查点不完整或未找到，从头开始训练")
                epoch_str = 1
                global_step = 0
                
        except Exception as e:
            if rank == 0:
                print(f"⚠️ 加载检查点失败: {e}, 从头开始训练")
            epoch_str = 1
            global_step = 0
            
        if skip_optimizer:
            epoch_str = 1
            global_step = 0
        # =========================

        # 学习率调度器
        warmup_epoch = hps.train.warmup_epochs
        scheduler_g = torch.optim.lr_scheduler.ExponentialLR(
            optim_g, gamma=hps.train.lr_decay, last_epoch=epoch_str-2
        )
        
        scheduler_d = torch.optim.lr_scheduler.ExponentialLR(
            optim_d, gamma=hps.train.lr_decay, last_epoch=epoch_str-2
        )

        scaler = GradScaler(enabled=hps.train.fp16_run)

        # 主训练循环
        for epoch in range(epoch_str, hps.train.epochs + 1):
            try:
                # 预热学习率
                if epoch <= warmup_epoch:
                    for param_group in optim_g.param_groups:
                        param_group['lr'] = hps.train.learning_rate / warmup_epoch * epoch
                    for param_group in optim_d.param_groups:
                        param_group['lr'] = hps.train.learning_rate / warmup_epoch * epoch
                
                # 训练和评估
                if rank == 0:
                    train_and_evaluate(
                        rank, epoch, hps, [net_g, net_d], [optim_g, optim_d], 
                        [scheduler_g, scheduler_d], scaler, [train_loader, eval_loader], 
                        logger, [writer, writer_eval], dirs
                    )
                else:
                    train_and_evaluate(
                        rank, epoch, hps, [net_g, net_d], [optim_g, optim_d], 
                        [scheduler_g, scheduler_d], scaler, [train_loader, None], 
                        None, None, dirs
                    )
                
                # 更新学习率
                scheduler_g.step()
                scheduler_d.step()
                
            except KeyboardInterrupt:
                if rank == 0:
                    print("\n🛑 训练中断 - 保存当前模型状态...")
                    save_interrupted_model(net_g, optim_g, net_d, optim_d, epoch, global_step, hps, dirs)
                raise
                
    except Exception as e:
        print(f"❌ GPU {rank} 上的训练失败: {e}")
        raise
        
    finally:
        # 清理分布式进程组
        if dist.is_initialized():
            dist.destroy_process_group()
        
        # 关闭TensorBoard写入器
        if writer:
            writer.close()
        if writer_eval:
            writer_eval.close()
            
        if rank == 0:
            print("✅ 训练进程完成")

def train_and_evaluate(rank, epoch, hps, nets, optims, schedulers, scaler, loaders, logger, writers, dirs):
    """每个epoch的训练和评估循环"""
    start_time = time.time()  # 初始化start_time变量
    net_g, net_d = nets